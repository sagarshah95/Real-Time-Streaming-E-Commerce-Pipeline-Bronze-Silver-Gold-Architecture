# --- MinIO root credentials (used by docker-compose for the minio service) ---
# Keep these as minioadmin/minioadmin because the minio-init container is
# hardcoded to log in with minioadmin/minioadmin to create the lakehouse bucket.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Used by Spark jobs (run INSIDE the docker network) ---
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
KAFKA_BOOTSTRAP_SERVER=kafka:9092
TOPIC=ecommerce-events

# --- Used by the producer (runs on your HOST machine) ---
BOOTSTRAP_SERVER=localhost:29092
